# Copy to .env.local and fill in real values. Never commit .env.local.
#
# For running the containerized app locally (docker-compose.override.yml)
# while still talking to real R2 + a real Cloudflare Queue - just the "dev"
# workspace's resources (see infra/opentofu), not production's.

PORT=8080
BASE_URL=http://localhost:8080
DB_PATH=/data/app.db

# Generate with: go run ./cmd/hashpw (or any bcrypt tool) for the password,
# and `openssl rand -hex 32` for the session secret. Can differ from your
# production .env - this is an entirely separate SQLite DB and session realm.
#
# IMPORTANT: Docker Compose interpolates $VAR / ${VAR} inside env_file values.
# A bcrypt hash contains literal `$` characters, so escape every `$` as `$$`
# here or Compose will silently mangle the hash (e.g. `$2a$10$abc...` ->
# `$$2a$$10$$abc...`) and login will fail with no obvious error.
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# From `tofu output` in infra/opentofu, in the "dev" workspace:
#   tofu workspace select dev
#   tofu output r2_bucket_name
#   tofu output -raw r2_access_key_id
#   tofu output -raw r2_secret_access_key
#   tofu output -raw cf_api_token
#   tofu output queue_id
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

CF_API_TOKEN=
CF_QUEUE_ID=
