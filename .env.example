# Copy to .env and fill in real values. Never commit .env.

PORT=8080
BASE_URL=https://share.yourdomain.com
DB_PATH=/data/app.db

# Generate with: go run ./cmd/hashpw (or any bcrypt tool) for the password,
# and `openssl rand -hex 32` for the session secret.
#
# IMPORTANT: Docker Compose interpolates $VAR / ${VAR} inside env_file values.
# A bcrypt hash contains literal `$` characters, so escape every `$` as `$$`
# here or Compose will silently mangle the hash (e.g. `$2a$10$abc...` ->
# `$$2a$$10$$abc...`) and login will fail with no obvious error.
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# From `tofu output` in infra/opentofu after apply.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

CF_API_TOKEN=
CF_QUEUE_ID=
