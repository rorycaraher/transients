# Copy to .env, fill in real values, then copy it to /etc/transients/env on
# the VPS (see README's Deploying section). Never commit .env.
#
# This is loaded by systemd's EnvironmentFile=, which treats each line as a
# literal KEY=VALUE pair with no shell expansion — so the bcrypt hash below
# needs no escaping here, unlike in Local mode's .env.local (see that file).

PORT=8090
BASE_URL=https://share.yourdomain.com
DB_PATH=/var/lib/transients/app.db

# Generate with: go run ./cmd/hashpw (or any bcrypt tool) for the password,
# and `openssl rand -hex 32` for the session secret.
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# From `tofu output` in infra/opentofu after apply.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

CF_API_TOKEN=
CF_QUEUE_ID=
