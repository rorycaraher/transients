# Add this site block to the Caddyfile already running on the VPS (do not
# replace the existing file — this just adds a new block alongside the one
# serving your other site). Replace the subdomain with the real one, then
# reload Caddy: `sudo systemctl reload caddy` or `caddy reload`.

transients.nothinglefttolearn.com {
	reverse_proxy 127.0.0.1:8090
}
